# 🌍 环境变量配置示例
# 复制此文件为 .env 并根据实际环境修改

# ========================
# 🗄️ 数据库配置
# ========================

# MySQL 数据库
MYSQL_HOST=192.168.31.17
MYSQL_PORT=13306
MYSQL_DB=demo_db
MYSQL_USER=root
MYSQL_PASSWORD=root

# ========================
# 🔐 安全配置
# ========================

# JWT 签名密钥 (重要：生产环境必须修改！)
# 生成命令: openssl rand -base64 32
JWT_SECRET=your-strong-jwt-secret-key-here

# JWT 过期时间 (毫秒，默认24小时)
JWT_EXPIRE=86400000

# ========================
# 🏗️ 服务发现与配置中心
# ========================

# Nacos 服务发现
NACOS_SERVER=192.168.31.17:18848

# ========================
# 🗃️ 缓存与消息队列
# ========================

# Redis
REDIS_HOST=192.168.31.17
REDIS_PORT=16379

# RocketMQ
ROCKETMQ_NAMESRV=192.168.31.17:19876

# ========================
# ⚙️ 服务端口配置
# ========================

# 服务端口 (可选，可在application.yml中配置)
# SERVICE_USER_PORT=28081
# SERVICE_ORDER_PORT=8082
# SERVICE_GATEWAY_PORT=28080

# ========================
# 📊 监控与日志
# ========================

# 日志级别 (可选)
# LOGGING_LEVEL_COM_EXAMPLE=DEBUG

# ========================
# 🚀 部署配置
# ========================

# 时区设置
TZ=Asia/Shanghai

# Java 内存配置 (可选)
# JAVA_OPTS=-Xmx512m -Xms256m

# ========================
# 🔧 功能配置
# ========================

# 函数执行超时时间 (毫秒)
FUNCTION_EXECUTE_TIMEOUT_MS=500

# ========================
# 📝 使用说明
# ========================

# 1. 复制此文件为 .env
#    cp .env.example .env

# 2. 根据实际环境修改 .env 文件中的配置

# 3. 启动服务时加载环境变量
#    方式1: 使用 docker-compose (推荐)
#    方式2: 使用 dotenv 工具
#    方式3: 手动设置环境变量

# 4. 生产环境注意事项:
#    - JWT_SECRET 必须使用强密码
#    - 数据库密码不要使用默认值
#    - 建议使用密钥管理服务

# ========================
# 🐳 Docker Compose 示例
# ========================

# version: '3.8'
# services:
#   service-user:
#     image: your-registry/service-user:latest
#     environment:
#       - JWT_SECRET=${JWT_SECRET}
#       - MYSQL_HOST=${MYSQL_HOST}
#       - MYSQL_PASSWORD=${MYSQL_PASSWORD}
#       # ... 其他环境变量
#     env_file:
#       - .env

# ========================
# 🔐 安全最佳实践
# ========================

# 1. JWT Secret 生成建议:
#    openssl rand -base64 32

# 2. 数据库密码复杂度:
#    - 至少12个字符
#    - 包含大小写字母、数字、特殊字符

# 3. 环境变量管理:
#    - 开发、测试、生产环境使用不同的 .env 文件
#    - 敏感信息不要提交到版本控制
#    - 使用密钥管理服务 (如 AWS Secrets Manager, HashiCorp Vault)

# ========================
# 📋 配置验证
# ========================

# 验证环境变量是否生效:
# 1. 启动服务后检查日志，确认配置加载
# 2. 访问健康检查端点
# 3. 测试关键功能 (如登录、JWT验证)

# 问题排查:
# 1. 检查环境变量名称是否正确
# 2. 检查环境变量是否被正确加载
# 3. 检查配置文件中的默认值

# ========================
# 🔄 配置更新流程
# ========================

# 1. 修改 .env 文件
# 2. 重启相关服务
# 3. 验证配置生效
# 4. 更新文档

# 注意: 某些配置可能需要重新编译或清理缓存